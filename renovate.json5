{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended"
  ],
  prConcurrentLimit: 3,
  prHourlyLimit: 6,
  addLabels: ["renovate"],
  major: {
    dependencyDashboardApproval: true
  },
  packageRules: [
    {
      matchDepNames: ["*"],
      enabled: false
    },
    {
      matchCategories: ["java"],
      enabled: true,
      groupName: "Gradle Dependencies"
    },
    {
      matchCategories: ["ci"], // for GitHub Actions
      enabled: true,
      groupName: "GitHub Actions"
    },
    {
      matchCategories: ["js"], // for wiki
      enabled: true,
      groupName: "NPM Dependencies"
    },
    {
      matchFileNames: ["**/dependencies.gradle"],
      enabled: true,
      groupName: "Mod Dependencies",
      "dependencyDashboardApproval": false
    }
  ]
}
