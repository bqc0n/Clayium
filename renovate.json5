{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended"
  ],
  prConcurrentLimit: 3,
  prHourlyLimit: 6,
  addLabels: ["renovate"],
  packageRules: [
    {
      matchFileNames: ["dependencies.gradle"],
      enabled: true,
      groupName: "Gradle Dependencies"
    },
    {
      matchCategories: ["github-actions"],
      enabled: true,
      groupName: "GitHub Actions"
    },
    {
      matchCategories: ["npm"],
      enabled: true,
      groupName: "NPM Dependencies"
    }
  ]
}
